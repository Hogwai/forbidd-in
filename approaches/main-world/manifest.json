{
  "manifest_version": 3,
  "name": "forbidd-in",
  "version": "2.0",
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*"],
    "js": ["main.js"],
    "run_at": "document_start",
    "world": "MAIN",
    "all_frames": true
  }]
}